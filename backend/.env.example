# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotelbhimas

# Environment
ENVIRONMENT=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin Access (set to false in production)
RESTRICT_ADMIN_ACCESS=true
ALLOWED_ADMIN_NETWORKS=192.168.0.0/16,127.0.0.1

# JWT/Authentication
SECRET_KEY=your_very_secure_random_key_min_32_characters_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Configuration
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_FROM=noreply@yourhotel.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# API Configuration
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO
